              "id": "CVE-2025-22228",
              "name": "LanguageSpecificPackageVulnerability",
              "shortDescription": {
                "text": "spring-security-core: Spring Security BCryptPasswordEncoder does not enforce maximum password length"
              },
              "fullDescription": {
                "text": "BCryptPasswordEncoder.matches(CharSequence,String) will incorrectly return true for passwords larger than 72 characters as long as the first 72 characters are the same."
